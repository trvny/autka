{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "cargate-backend",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-02",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "cargate-offers",
      "database_id": "50fde2d6-d2f2-4607-9961-729b462b115b",
      "migrations_dir": "migrations"
    }
  ],
  // R2 stores offer images (bucket: cargate-images).
  "r2_buckets": [
    { "binding": "IMAGES", "bucket_name": "cargate-images" }
  ],
  "triggers": {
    // Re-run ingestion hourly. Each run re-upserts every offer and writes one
    // ingest_runs row per source, so fewer runs = fewer D1 rows written/day —
    // the binding limit on the Workers Free plan. (Was */30.)
    "crons": ["0 * * * *"]
  },
  "vars": {
    "ENVIRONMENT": "production"
  }
}
