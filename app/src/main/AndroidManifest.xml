<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".CarFinderApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.CarFinder"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Google Maps API key, supplied via manifestPlaceholder from local.properties.
             The map screen degrades to a message when this is empty/unset. -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <!-- Primary entry: CarGate (inherits the application label) -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.CarFinder">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
          Secondary brand alias: "CarFinder".
          Launches the same MainActivity. With the LAUNCHER category below it appears as
          a second launcher entry/icon labelled CarFinder. To keep CarFinder only as a
          named alias WITHOUT a second home-screen icon, delete the <intent-filter>.
        -->
        <activity-alias
            android:name=".CarFinderActivity"
            android:targetActivity=".MainActivity"
            android:label="@string/app_name_alias"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>
    </application>
</manifest>
